DEVICE-PROGRAM 1.0;
// e02_qubit_conflict {backend=dualrail}  (PHYS = physical op, SYS = system call)
[0,1)us  SYS   request_ancilla    q[100]
[0,1)us  SYS   request_ancilla    q[101]
[1,2)us  PHYS  gate2q             q[0],q[100] gate=CNOT
[1,2)us  PHYS  gate2q             q[0],q[101] gate=CNOT
[2,3)us  PHYS  measure            q[100] basis=Z
[2,3)us  PHYS  measure            q[101] basis=Z
