{
  "title": "Cuccaro 2-bit adder  (a + b mod 4)   [n = 2 bits per addend]",
  "wires": ["c_in", "b0", "a0", "b1", "a1"],
  "input": ["c_in = 0 (carry-in)", "(b1,b0) = b  (addend / target reg)", "(a1,a0) = a  (read reg)"],
  "output": ["c_in = 0 (restored)", "(b1,b0) = (a+b) mod 4  (sum)", "(a1,a0) = a  (restored)"]
}
