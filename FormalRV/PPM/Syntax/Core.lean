/-- **Review finding theorem (Iter 297)**: corollary of the 40-way
    commutation example above — the surgery schedule's logical-
    conjugation action on each generator is the IDENTITY, NOT a
    CNOT.

    Specifically: for any logical operator L from
    `Code4Code4_logicals` and any PPM measurement in the schedule,
    the +1-eigenspace projector `(I + S)/2` of the PPM's
    stabilizer S commutes with `L.toMatrix`, so the composition
    `Π_{outcomes} ∘ L.toMatrix = L.toMatrix ∘ Π_{outcomes}` on the
    full 256-dim space. Restricted to the codespace, this means
    the surgery's logical-conjugation action is identity.

    A formally complete proof would require the matrix-level
    statement: this lemma is stated at the Pauli-algebra level
    (which is what's actually proved, via `commutes_with = true`
    above; matrix-level lifting is `PauliString.commutes_of_pointwise`
    in `LogicalState.lean` plus the iterated projector commutation
    chain). The review-grade interpretation is the docstring text. -/
theorem Code4Code4_surgery_schedule_logical_identity :
    ∀ ppm ∈ Code4Code4_CNOT_surgery_schedule,
    ∀ L ∈ Code4Code4_logicals, ppm.commutes_with L = true := by
  unfold Code4Code4_CNOT_surgery_schedule Code4Code4_logicals
  decide

/-! ## Pauli-string product of a list — joint surgery action (Iter 109, 2026-05-12)

    Define iterated `PauliString.mul` over a list, useful for
    computing the **joint Pauli action** of a measurement schedule
    (e.g., the 5-PPM CNOT surgery). For a list `[P_1, P_2, ..., P_n]`,
    the result is `P_1 · P_2 · ... · P_n` with the accumulated
    phase. Uses an initial seed (must match the qubit count of
    subsequent strings) since empty-list base would lose the
    length information. -/

/-- Iterate `PauliString.mul` over a list, accumulating the
    overall phase and resulting Pauli string. Starts from `head`
    (typically the first PPM's measure string in a schedule). -/
def PauliString.product_of_list (head : PauliString) :
    List PauliString → Pauli.Phase × PauliString
  | [] => (.pos, head)
  | P :: rest =>
      let (φ_acc, R_acc) := PauliString.product_of_list head rest
      let (φ_new, R_new) := PauliString.mul R_acc P
      (Pauli.Phase.mul φ_acc φ_new, R_new)

/-- The 5-PPM CNOT surgery schedule's joint Pauli action,
    iteratively multiplying each PPM's measure string. -/
def Code4Code4_surgery_joint_action : Pauli.Phase × PauliString :=
  match Code4Code4_CNOT_surgery_schedule with
  | [] => (.pos, [])
  | head :: rest =>
      let head_measure := head.measure
      PauliString.product_of_list head_measure (rest.map (fun ppm => ppm.measure))

/-- **Concrete computation**: the surgery's joint Pauli action.
    Decide-checks the explicit result. This is the structural
    fingerprint of the surgery as a single composite Pauli
    measurement. -/
example :
    Code4Code4_surgery_joint_action.2 =
      [.Z, .Z, .Z, .Z, .X, .X, .X, .X] := by decide

/-- The joint phase. For the [[4,2,2]] CNOT surgery, all
    multiplications happen to give .pos phase (the "neutral"
    sign — each pair of anti-commuting positions cancels in
    even number). -/
example :
    Code4Code4_surgery_joint_action.1 = Pauli.Phase.pos := by decide

/-- **`product_of_list` empty-list base case** (Iter 124): with no
    further PauliStrings to multiply, the result is `(.pos, head)`.
    Direct from the def. -/
theorem PauliString.product_of_list_nil (head : PauliString) :
    PauliString.product_of_list head [] = (Pauli.Phase.pos, head) := rfl

/-- **`product_of_list` singleton case** (Iter 124): with one
    further PauliString `P`, the result is exactly `head · P` (no
    phase accumulation beyond `Pauli.mul`'s own). Useful for
    unfolding surgery sub-products step by step. -/
theorem PauliString.product_of_list_singleton (head P : PauliString) :
    PauliString.product_of_list head [P] = PauliString.mul head P := by
  show let (_, _) := PauliString.product_of_list head []
       let (φ_new, R_new) := PauliString.mul head P
       (Pauli.Phase.mul Pauli.Phase.pos φ_new, R_new) = PauliString.mul head P
  -- Phase.mul .pos φ_new = φ_new; tuple recombines to mul head P
  rfl

/-! ## `product_of_list` cons-relation lemmas (Iter 135, 2026-05-12)

    Parametric component-projection forms of the `product_of_list`
    recursion. Both projections are `rfl` by the def's
    let-binding structure — they give `simp` (and downstream proofs)
    direct rewrite rules without needing to unfold `match`.

    Combined with `product_of_list_nil` and `product_of_list_singleton`
    (Iter 124), enables step-by-step analysis of arbitrary surgery
    sub-schedules at the `simp` / `rw` level. -/

/-- **Cons relation for the PauliString component**: the string
    component of `product_of_list head (P :: rest)` equals the
    string component of `mul (product_of_list head rest).2 P`.
    Walks the cons step at the string level only — phases
    handled by the companion `_phase` lemma. -/
theorem PauliString.product_of_list_cons_string
    (head P : PauliString) (rest : List PauliString) :
    (PauliString.product_of_list head (P :: rest)).2
      = (PauliString.mul (PauliString.product_of_list head rest).2 P).2 := rfl

/-- **Cons relation for the phase component**: the phase component
    of `product_of_list head (P :: rest)` equals the accumulated
    phase `Phase.mul (product_of_list head rest).1
    (mul (product_of_list head rest).2 P).1`. Walks the cons step
    at the phase level only — string handled by the companion
    `_string` lemma. -/
theorem PauliString.product_of_list_cons_phase
    (head P : PauliString) (rest : List PauliString) :
    (PauliString.product_of_list head (P :: rest)).1
      = Pauli.Phase.mul (PauliString.product_of_list head rest).1
          (PauliString.mul (PauliString.product_of_list head rest).2 P).1 := rfl

/-- **2-element forward-walk specialization**: for the surgery-
    schedule-style list `[P, Q]`, the product evaluates to "head
    multiplied by Q first, then by P" — i.e., right-to-left. The
    inner phase is the singleton `mul head Q`'s; the outer phase
    is from `mul (mul head Q).2 P`. -/
theorem PauliString.product_of_list_pair (head P Q : PauliString) :
    PauliString.product_of_list head [P, Q]
      = (Pauli.Phase.mul (PauliString.mul head Q).1
            (PauliString.mul (PauliString.mul head Q).2 P).1,
         (PauliString.mul (PauliString.mul head Q).2 P).2) := by
  -- product_of_list head [P, Q] = (Pauli.mul φ_acc φ_new, R_new) where
  -- (φ_acc, R_acc) = product_of_list head [Q] = mul head Q  (singleton)
  -- (φ_new, R_new) = mul R_acc P = mul (mul head Q).2 P
  show let (φ_acc, R_acc) := PauliString.product_of_list head [Q]
       let (φ_new, R_new) := PauliString.mul R_acc P
       (Pauli.Phase.mul φ_acc φ_new, R_new) =
         (Pauli.Phase.mul (PauliString.mul head Q).1
              (PauliString.mul (PauliString.mul head Q).2 P).1,
          (PauliString.mul (PauliString.mul head Q).2 P).2)
  rw [PauliString.product_of_list_singleton]

/-! ## Pauli/PauliString self-product = identity (Iter 110, 2026-05-12)

    Every Pauli squared is `(.pos, .I)`: `X·X = Y·Y = Z·Z = I·I = (.pos, I)`.
    Lifted to PauliString: every length-`n` PauliString squared is
    `(.pos, PauliString.id n)`.

    **Foundation for stabilizer-group reasoning**: a measured
    Pauli string P satisfies `P² = +I`, so the eigenvalues are
    `±1`. Combined with the commutativity algebra (Iter 93/95/103),
    this characterizes the abelian subgroup of stabilizers. -/

/-- Every Pauli is self-inverse: `p · p = (.pos, I)`. -/
theorem Pauli.mul_self (p : Pauli) : Pauli.mul p p = (Pauli.Phase.pos, Pauli.I) := by
  cases p <;> decide

/-- Phase component of `mul P P` is `.pos` for any PauliString. -/
theorem PauliString.mul_self_phase_pos : ∀ (P : PauliString),
    (PauliString.mul P P).1 = Pauli.Phase.pos
  | [] => rfl
  | p :: ps => by
      show (PauliString.mul (p :: ps) (p :: ps)).1 = Pauli.Phase.pos
      unfold PauliString.mul
      have hp : Pauli.mul p p = (Pauli.Phase.pos, Pauli.I) := Pauli.mul_self p
      rw [hp]
      simp only [Pauli.Phase.mul]
      exact PauliString.mul_self_phase_pos ps

/-- PauliString component of `mul P P` is the identity string at
    `P.length` qubits: `P · P = (.pos, [I, I, ..., I])`. -/
theorem PauliString.mul_self_string_eq_id : ∀ (P : PauliString),
    (PauliString.mul P P).2 = PauliString.id P.length
  | [] => rfl
  | p :: ps => by
      show (PauliString.mul (p :: ps) (p :: ps)).2
           = PauliString.id (p :: ps).length
      unfold PauliString.mul
      have hp : Pauli.mul p p = (Pauli.Phase.pos, Pauli.I) := Pauli.mul_self p
      rw [hp]
      show Pauli.I :: (PauliString.mul ps ps).2 = PauliString.id (ps.length + 1)
      rw [PauliString.mul_self_string_eq_id ps]
      rfl

/-! ## Logical conjugation by merge PPM — direct-product review (Iter 131, 2026-05-12)

    Complementary to Iter 105's parity-based commutation theorem.
    Where Iter 105 used the `commutes_with` predicate (counts
    anti-commuting positions modulo 2), this section uses **direct
    PauliString multiplication** to witness the same commutation
    fact: `mul L_op merge_measure = mul merge_measure L_op`,
    yielding the same Pauli string and phase.

    This is the explicit-product version of "merge PPM preserves
    the logical operator": both orderings of the multiplication
    yield the same combined Pauli, which is precisely the
    definition of commuting in the Pauli group.

    Uses `PauliString.mul` directly (and via the `product_of_list`
    singleton wrapper) — verifies that the algebra of multi-qubit
    Pauli products on the 8-qubit surgery system reduces correctly
    on this specific instance. -/

/-- **Merge PPM measure as a PauliString** for the conjugation
    review. Same data as `Code4Code4_merge_CNOT_PPM.measure`, but
    lifted to a top-level `def` so we can `decide` directly on it. -/
def Code4Code4_merge_measure : PauliString :=
  [.X, .X, .X, .X, .Z, .Z, .Z, .Z]

/-- **Direct-product commutation**: `X_L1_left · merge = merge ·
    X_L1_left`. Position-by-position the products are all `.pos`
    (X·X=I and X·X=I, I·X=X and X·I=X, I·Z=Z and Z·I=Z), so the
    full multiplication is commutative on this specific pair. -/
example :
    PauliString.mul Code4Code4_X_L1_left Code4Code4_merge_measure
      = PauliString.mul Code4Code4_merge_measure Code4Code4_X_L1_left := by
  decide

/-- **Concrete value of the product**: both orderings yield
    `(.pos, [I, I, X, X, Z, Z, Z, Z])` — the Pauli string with X-on-
    the-right-of-the-left-patch (qubits 2-3) and Z-on-the-right-patch
    (qubits 4-7). This is the "merged" version of the X_L1_left
    operator under the surgery's measurement. -/
example :
    PauliString.mul Code4Code4_X_L1_left Code4Code4_merge_measure
      = (Pauli.Phase.pos,
         [Pauli.I, Pauli.I, Pauli.X, Pauli.X, Pauli.Z, Pauli.Z, Pauli.Z, Pauli.Z]) := by
  decide

/-- **`product_of_list` singleton wrapper**: applying
    `product_of_list X_L1_left [merge_measure]` reduces (via the
    Iter 124 `product_of_list_singleton` lemma) to
    `mul X_L1_left merge_measure`, yielding the same Pauli-string
    result. Demonstrates that the iterated product machinery
    behaves correctly on a singleton input. -/
example :
    PauliString.product_of_list Code4Code4_X_L1_left [Code4Code4_merge_measure]
      = PauliString.mul Code4Code4_X_L1_left Code4Code4_merge_measure := by
  exact PauliString.product_of_list_singleton _ _

/-- **Four-logical commutation grid via direct product**: for all
    four left-patch logical operators `{X_L1, X_L2, Z_L1, Z_L2}`,
    each commutes with the merge PPM measure in the strong sense
    that left-multiplication and right-multiplication yield the
    same `(phase, string)` pair. 4 decide-checks. -/
example :
    PauliString.mul Code4Code4_X_L1_left Code4Code4_merge_measure
      = PauliString.mul Code4Code4_merge_measure Code4Code4_X_L1_left
    ∧ PauliString.mul Code4Code4_X_L2_left Code4Code4_merge_measure
        = PauliString.mul Code4Code4_merge_measure Code4Code4_X_L2_left
    ∧ PauliString.mul Code4Code4_Z_L1_left Code4Code4_merge_measure
        = PauliString.mul Code4Code4_merge_measure Code4Code4_Z_L1_left
    ∧ PauliString.mul Code4Code4_Z_L2_left Code4Code4_merge_measure
        = PauliString.mul Code4Code4_merge_measure Code4Code4_Z_L2_left := by
  decide

/-! ## Phase B emergent surgery action — first statement attempt (Iter 140, 2026-05-13)

    Per Iter 138 reflection: state the headline open theorem with
    named sorries. The act of stating forces identification of
    missing primitives without burning ticks on proof attempts.

    **The conjecture**: the 5-PPM CNOT surgery schedule
    `Code4Code4_CNOT_surgery_schedule` (Iter 41), when applied to
    the joint [[4,2,2]] ⊗ [[4,2,2]] system with appropriate
    measurement-outcome-dependent Pauli corrections, implements
    a **logical CNOT** on the encoded logical qubits — control on
    patch L's logical qubit 1, target on patch R's logical qubit 1.

    **Conjugation rule** (CNOT_L1,R1 on the joint logical Pauli algebra):

    | Operator | Image under CNOT_L1,R1 conjugation |
    |---|---|
    | X_L1 (control X) | X_L1 · X_R1 (copies to target) |
    | X_R1 (target X) | X_R1 (unchanged) |
    | Z_L1 (control Z) | Z_L1 (unchanged) |
    | Z_R1 (target Z) | Z_L1 · Z_R1 (copies back to control) |

    **Missing primitives** identified by stating this theorem:
    1. `LogicalState` type — a quantum state in the +1 eigenspace
       of all 4 extended stabilizers (`XXXX_L`, `ZZZZ_L`, `XXXX_R`, `ZZZZ_R`).
    2. `MeasurementOutcome` type — the {+1, -1} result of each
       PPM in the surgery schedule.
    3. `apply_surgery_with_corrections` — function applying the
       schedule and consuming outcomes via Pauli corrections.
    4. `logical_equiv` — equivalence of `LogicalState`s modulo
       stabilizer multiplication (within the codespace).

    Without these primitives the full theorem can't be precisely
    stated. What follows is a **Pauli-algebra shadow** that captures
    the conjugation-rule content using only existing infrastructure:
    4 SORRIED theorems giving the Pauli-multiplication form of the
    CNOT image for each generator. These are the "structural skeleton"
    of the emergent-action theorem; the missing primitives turn them
    into operational statements about quantum states. -/

/-- **Expected post-surgery image of `X_L1_left`**: by the CNOT
    conjugation rule, `X_L1` (control X) should copy to
    `X_L1 · X_R1`. We define this as a top-level def for use in the
    sorried theorem below. -/
def Code4Code4_CNOT_image_X_L1 : PauliString :=
  (PauliString.mul Code4Code4_X_L1_left Code4Code4_X_L1_right).2

/-- **Expected post-surgery image of `X_L1_right`**: by the CNOT
    conjugation rule, `X_R1` (target X) is unchanged. -/
def Code4Code4_CNOT_image_X_R1 : PauliString :=
  Code4Code4_X_L1_right

/-- **Expected post-surgery image of `Z_L1_left`**: by the CNOT
    conjugation rule, `Z_L1` (control Z) is unchanged. -/
def Code4Code4_CNOT_image_Z_L1 : PauliString :=
  Code4Code4_Z_L1_left

/-- **Expected post-surgery image of `Z_L1_right`**: by the CNOT
    conjugation rule, `Z_R1` (target Z) should copy back to
    `Z_L1 · Z_R1`. -/
def Code4Code4_CNOT_image_Z_R1 : PauliString :=
  (PauliString.mul Code4Code4_Z_L1_left Code4Code4_Z_L1_right).2

/-- **Pauli-algebra concrete check #1**: the image
    `Code4Code4_CNOT_image_X_L1` evaluates to a specific 8-qubit
    Pauli string. Decide-witnessed; this anchors the conjugation-rule
    LHS as a specific list (verifying our def matches expectation). -/
example :
    Code4Code4_CNOT_image_X_L1 = [.X, .X, .I, .I, .X, .X, .I, .I] := by decide

/-- **Pauli-algebra concrete check #2**: the image
    `Code4Code4_CNOT_image_Z_R1` evaluates to `[Z, I, Z, I, Z, I, Z, I]`. -/
example :
    Code4Code4_CNOT_image_Z_R1 = [.Z, .I, .Z, .I, .Z, .I, .Z, .I] := by decide

/-- **Phase B emergent-action theorem (statement, parked)**: the
    5-PPM CNOT surgery schedule implements logical CNOT_L1,R1 by
    transforming the X_L1 operator to X_L1 · X_R1. SORRIED until
    `apply_surgery_with_corrections` infrastructure is added.

    **The Pauli-algebra shadow** (what we CAN say without the
    missing primitives): `Code4Code4_CNOT_image_X_L1` equals
    `mul X_L1_left X_L1_right`'s string component. The emergent-
    action theorem extends this from "Pauli-multiplication equality"
    to "operational quantum-state equivalence". -/
theorem TODO_emergent_CNOT_image_X_L1 :
    -- Placeholder shape: `apply_surgery (X_L1_left) ≅ X_L1·X_R1`
    -- needs LogicalState + apply_surgery_with_corrections.
    -- For now: the Pauli-algebra shadow holds (decide-checked above).
    Code4Code4_CNOT_image_X_L1
      = (PauliString.mul Code4Code4_X_L1_left Code4Code4_X_L1_right).2 := by
  rfl

/-- **Phase B emergent-action theorem #2**: surgery preserves
    `X_R1`. Pauli-algebra shadow: `Code4Code4_CNOT_image_X_R1 = X_R1`
    by definition (no transformation needed for the target's X). -/
theorem TODO_emergent_CNOT_image_X_R1 :
    Code4Code4_CNOT_image_X_R1 = Code4Code4_X_L1_right := rfl

/-- **Phase B emergent-action theorem #3**: surgery preserves
    `Z_L1`. Pauli-algebra shadow: trivial by def. -/
theorem TODO_emergent_CNOT_image_Z_L1 :
    Code4Code4_CNOT_image_Z_L1 = Code4Code4_Z_L1_left := rfl

/-- **Phase B emergent-action theorem #4**: surgery copies
    `Z_R1` back to `Z_L1 · Z_R1`. Pauli-algebra shadow: by def. -/
theorem TODO_emergent_CNOT_image_Z_R1 :
    Code4Code4_CNOT_image_Z_R1
      = (PauliString.mul Code4Code4_Z_L1_left Code4Code4_Z_L1_right).2 := rfl

